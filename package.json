{
  "name": "wechat-claude-code-win",
  "version": "1.0.0",
  "description": "Windows-friendly WeChat to Claude Code bridge for local development",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/main.js",
    "dev": "tsc --watch",
    "test": "node --test dist/tests/*.test.js",
    "setup": "node dist/main.js setup",
    "daemon": "bash scripts/daemon.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.7.0"
  },
  "keywords": ["wechat", "claude-code", "claude", "bridge", "chat", "skill"],
  "author": "Wechat-ggGitHub",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wentaiyang/wechat-claude-code-win.git"
  }
}
